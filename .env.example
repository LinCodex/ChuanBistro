# Gemini API key — required to generate AI reviews.
#
# Two names are accepted (vite.config.ts forwards either to the bundle):
#   VITE_GEMINI_API_KEY  — preferred, follows the Vite convention.
#   GEMINI_API_KEY       — legacy name used by AI Studio.
#
# WARNING: this key is bundled into the static client. Do NOT use a key with
# billing or sensitive scopes in a publicly hosted deployment. For production
# you should proxy Gemini through a backend and never ship the key to the
# browser.
VITE_GEMINI_API_KEY="your-gemini-api-key-here"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL="MY_APP_URL"
